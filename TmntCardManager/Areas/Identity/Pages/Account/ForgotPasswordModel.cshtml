@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Відновлення пароля";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card bg-dark text-light shadow-lg" style="border: 2px solid #198754; border-radius: 15px;">
            <div class="card-header border-bottom border-success text-center p-4">
                <h2 class="text-success mb-0 fw-bold"> @ViewData["Title"]</h2>
            </div>
            <div class="card-body p-4 p-md-5">
                <p class="text-muted text-center mb-4">Введіть свій email, і ми надішлемо вам інструкції для скидання пароля.</p>
                
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
                    
                    <div class="form-floating mb-4">
                        <input asp-for="Input.Email" class="form-control bg-secondary text-white border-success" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                        <label asp-for="Input.Email" class="text-light">Ваш Email</label>
                        <span asp-validation-for="Input.Email" class="text-warning"></span>
                    </div>
                    
                    <button type="submit" class="btn btn-success btn-lg w-100 fw-bold shadow">Надіслати посилання</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}