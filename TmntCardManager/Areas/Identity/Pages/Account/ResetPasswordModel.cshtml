@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Скидання пароля";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card bg-dark text-light shadow-lg" style="border: 2px solid #198754; border-radius: 15px;">
            <div class="card-header border-bottom border-success text-center p-4">
                <h3 class="text-success mb-0 fw-bold"> Придумати новий пароль</h3>
            </div>
            <div class="card-body p-4 p-md-5">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
                    
                    <input asp-for="Input.Code" type="hidden" />
                    
                    <div class="form-floating mb-3">
                        <input asp-for="Input.Email" class="form-control bg-secondary text-white border-success" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                        <label asp-for="Input.Email" class="text-light">Ваш Email</label>
                        <span asp-validation-for="Input.Email" class="text-warning"></span>
                    </div>
                    
                    <div class="form-floating mb-3">
                        <input asp-for="Input.Password" class="form-control bg-secondary text-white border-success" autocomplete="new-password" aria-required="true" placeholder="Пароль" />
                        <label asp-for="Input.Password" class="text-light">Новий пароль</label>
                        <span asp-validation-for="Input.Password" class="text-warning"></span>
                    </div>
                    
                    <div class="form-floating mb-4">
                        <input asp-for="Input.ConfirmPassword" class="form-control bg-secondary text-white border-success" autocomplete="new-password" aria-required="true" placeholder="Пароль" />
                        <label asp-for="Input.ConfirmPassword" class="text-light">Підтвердіть пароль</label>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-warning"></span>
                    </div>
                    
                    <button type="submit" class="btn btn-success btn-lg w-100 fw-bold shadow">Зберегти пароль</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}