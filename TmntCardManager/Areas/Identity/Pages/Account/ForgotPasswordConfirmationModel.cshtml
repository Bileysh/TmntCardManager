@page
@model ForgotPasswordConfirmationModel
@{
    ViewData["Title"] = "Лист надіслано";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 text-center">
        <div class="card bg-dark text-light border-success shadow-lg" style="border-width: 2px; border-radius: 15px;">
            <div class="card-body p-5">
                <div class="mb-4">
                    <span style="font-size: 5rem; color: #198754;"></span>
                </div>
                <h2 class="text-success fw-bold mb-4">@ViewData["Title"]</h2>
                <p class="text-light fs-5">
                    Будь ласка, перевірте свою електронну пошту. Ми надіслали вам посилання для скидання пароля.
                </p>
                <p class="text-muted mt-3 small">
                    Якщо листа немає у "Вхідних", перевірте папку "Спам".
                </p>
            </div>
        </div>
    </div>
</div>