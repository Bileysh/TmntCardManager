@page
@model ResetPasswordConfirmationModel
@{
    ViewData["Title"] = "Пароль змінено";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 text-center">
        <div class="card bg-dark text-light border-success shadow-lg" style="border-width: 2px; border-radius: 15px;">
            <div class="card-body p-5">
                <div class="mb-4">
                    <span style="font-size: 5rem; color: #198754;">✓</span>
                </div>
                <h2 class="text-success fw-bold mb-4">@ViewData["Title"]</h2>
                <p class="text-light fs-5 mb-4">
                    Ваш пароль було успішно змінено! Тепер ви можете повернутися в гру.
                </p>
                <a asp-page="./Login" class="btn btn-outline-success btn-lg px-5 shadow">Увійти в акаунт</a>
            </div>
        </div>
    </div>
</div>