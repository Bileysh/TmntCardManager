@model TmntCardManager.Models.Card

@{
    ViewData["Title"] = "Delete";
}

<h1>Видалити карту</h1>

<h3>Ви впевнені, що хочете це видалити?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Imageurl)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Imageurl)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Name)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Name)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Strength)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Strength)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Agility)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Agility)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Skill)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Skill)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Wit)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Wit)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Class)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Class.Name)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Видалити" class="btn btn-danger" /> |
        @if (ViewBag.ReturnFactionId != null)
        {
            <a asp-action="Index" asp-route-id="@ViewBag.ReturnFactionId">Назад до списку карт фракцій</a>
        }
        else
        {
            <a asp-action="Index">Назад до всіх карт</a>
        }
        </form>
</div>
