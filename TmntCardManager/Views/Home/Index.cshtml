@{
    ViewData["Title"] = "Головна";
}

<div class="text-center mt-5">
    <h1 class="display-3 text-success fw-bold" style="text-shadow: 0 0 15px rgba(25, 135, 84, 0.5);">Вітаємо у TMNT Card Manager!</h1>
    
    <p class="fs-4 text-white mt-4 mb-5">Збирай свою ідеальну колоду, керуй фракціями та перемагай.</p>
    
    @if (!User.Identity?.IsAuthenticated ?? true)
    {
        <div class="mt-5 d-flex justify-content-center gap-4">
            <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-success btn-lg px-5 py-3 fs-5 fw-bold shadow-lg">Зібрати свою колоду</a>
            <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-outline-light btn-lg px-5 py-3 fs-5 fw-bold border-white text-white shadow-lg">Я вже з вами</a>
        </div>
    }
    else
    {
        <div class="mt-5">
            <a asp-controller="Decks" asp-action="Index" class="btn btn-success btn-lg px-5 py-3 fs-5 fw-bold shadow-lg">Перейти до моїх колод</a>
        </div>
    }
</div>