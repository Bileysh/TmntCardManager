@model TmntCardManager.Models.User

@{
    ViewData["Title"] = "Delete";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Видалити користувача</h1>

<h3>Ви впевнені, що хочете це видалити?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Email)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Email)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Passwordhash)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Passwordhash)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Role)
        </dt>
        <dd class="col-sm-10">
            @if (Model.Role == "User")
            {
                <span class="badge bg-primary">Користувач</span>
            }
            else if (Model.Role == "Admin")
            {
                <span class="badge bg-danger">Адміністратор</span>
            }
            else
            {
                @Model.Role
            }
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Видалити" class="btn btn-danger" /> |
        <a asp-action="Index">Назад до списку</a>
    </form>
</div>
