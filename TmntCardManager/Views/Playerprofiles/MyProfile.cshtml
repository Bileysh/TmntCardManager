@model TmntCardManager.Models.Playerprofile

@{
    ViewData["Title"] = "Мій профіль";
    var defaultAvatar = "https://cdn.pixabay.com/photo/2015/10/05/22/37/blank-profile-picture-973460_960_720.png";
    var displayAvatar = string.IsNullOrWhiteSpace(Model.Avatarurl) ? defaultAvatar : Model.Avatarurl;
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <div class="card bg-dark text-light shadow-lg" style="border: 2px solid #198754; border-radius: 15px;">
            <div class="card-header border-bottom border-success text-center p-3">
                <h3 class="text-success mb-0 fw-bold"> @ViewData["Title"]</h3>
            </div>
            <div class="card-body text-center p-4">
                
                <img src="@displayAvatar" alt="Avatar" class="rounded-circle mb-3 shadow-lg" 
                     style="width: 150px; height: 150px; object-fit: cover; border: 4px solid #198754; background-color: #212529;" 
                     onerror="this.src='@defaultAvatar'" />
                
                <h2 class="mb-1 fw-bold text-white">@Model.Nickname</h2>
                <p class="text-black mb-3 fs-6">@ViewBag.Email</p> 
                <p class="text-light mb-4 fs-5">Відсоток перемог: <strong class="text-warning">@Model.Winrate %</strong></p>

                <hr class="border-success mb-4" />

                <form asp-action="UpdateProfile" method="post" class="text-start">
                    <input type="hidden" asp-for="Id" />
                    
                    <div class="mb-3">
                        <label asp-for="Nickname" class="form-label text-black fw-bold ">Нікнейм у грі</label>
                        <input asp-for="Nickname" class="form-control bg-light-subtle text-black border-success" placeholder="Введіть нікнейм" required />
                    </div>
                    
                    <div class="mb-4">
                        <label asp-for="Avatarurl" class="form-label text-black fw-bold">Посилання на аватар (URL)</label>
                        <input asp-for="Avatarurl" class="form-control bg-light-subtle text-black border-success" 
                               style="text-overflow: ellipsis; overflow: hidden;" placeholder="https://..." />
                        <div class="form-text text-light mt-1 opacity-75">Залиште порожнім для стандартної картинки.</div>
                    </div>

                    <button type="submit" class="btn btn-success btn-lg w-100 fw-bold shadow">Зберегти зміни Профілю</button>
                </form>

            </div>
        </div>
    </div>
</div>