@model TmntCardManager.Models.Deckcard

@{
    ViewData["Title"] = "Create";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Додати в колоду</h1>

<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Deckid" class="control-label"></label>
                <select asp-for="Deckid" class ="form-control" asp-items="ViewBag.Deckid"></select>
            </div>
            
            <div class="form-group">
                <label asp-for="Cardid" class="control-label"></label>
                <select asp-for="Cardid" class ="form-control" asp-items="ViewBag.Cardid"></select>
            </div>
            <div class="form-group">
                <input type="submit" value="Додати" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-controller="Decks" asp-action="Index">Повернутися до списку колод</a></div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
